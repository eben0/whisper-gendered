PORT=9000
WHISPER_MODEL=large-v3
COMPUTE_TYPE=float16
DEVICE=cuda
CONCURRENT_JOBS=1
# Language name (e.g. "Hebrew") or "none" to transcribe only.
TARGET_LANGUAGE=Hebrew
# https://huggingface.co/settings/tokens — also accept the pyannote 3.1 license.
HF_TOKEN=your_huggingface_token
ANTHROPIC_API_KEY=your_anthropic_key
CLAUDE_MODEL=claude-sonnet-4-6
GENDER_THRESHOLD_HZ=165
DEBUG=false
CHUNK_DURATION_SEC=300
TRANSLATE_CONCURRENCY=3
CLAUDE_MAX_RETRIES=4
# Pass previous group's speaker gender as the "you" addressee hint.
ADDRESSEE_GENDER_HINT_ENABLED=true
# Optional: also write SRT next to the source video on a mounted share.
# Set BOTH prefixes (client mount view → server mount view) to enable.
SAVE_SRT_VIDEO_PREFIX=
SAVE_SRT_LOCAL_PREFIX=
SAVE_SRT_SUFFIX=.he.srt
# "claude" (API) | "local" (HF seq2seq on the Whisper GPU).
TRANSLATION_BACKEND=claude
# Default fits in ~1.2 GB VRAM at float16. Alternative: Helsinki-NLP/opus-mt-en-he.
LOCAL_TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
LOCAL_TRANSLATION_DEVICE=cuda
LOCAL_TRANSLATION_DTYPE=float16
LOCAL_BATCH_SIZE=16
LOCAL_MAX_LENGTH=512
# Prepend a gender hint to the source text (off by default — local models don't follow instructions).
LOCAL_USE_GENDER_PREFIX=false
# "pitch" (default) | "ml" (wav2vec2) | "ensemble" (both, ML wins).
GENDER_CLASSIFIER=pitch
# HF model id for the ML classifier; loaded lazily on first use. ~1.2 GB on disk.
GENDER_ML_MODEL=alefiury/wav2vec2-large-xlsr-53-gender-recognition-librispeech
# WARN when ML wall time > pitch wall time × this. 0 disables.
GENDER_ML_TIME_BUDGET_RATIO=5.0
# Also emit a second SRT using the alternate classifier (A/B side-by-side).
GENDER_AB_OUTPUT=false
# Preceding source-language segments injected as "earlier in this scene". 0 disables.
TRANSLATE_CONTEXT_LINES=4
