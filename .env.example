PORT=9000
WHISPER_MODEL=large-v3
COMPUTE_TYPE=float16
DEVICE=cuda
CONCURRENT_JOBS=1
# Set to a language name to enable translation, or "none" to transcribe only.
# Gender-aware languages (Hebrew, Arabic, French, Spanish, etc.) will automatically
# trigger speaker diarization and gender detection for grammatically correct output.
TARGET_LANGUAGE=Hebrew
# Required for pyannote diarization. Get one at https://huggingface.co/settings/tokens
# and accept the model license at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_huggingface_token
ANTHROPIC_API_KEY=your_anthropic_key
CLAUDE_MODEL=claude-sonnet-4-6
GENDER_THRESHOLD_HZ=165
DEBUG=false
# Chunked pipeline tuning
CHUNK_DURATION_SEC=300
TRANSLATE_CONCURRENCY=3
CLAUDE_MAX_RETRIES=4
# Toggle the per-group addressee gender hint (the previous group's speaker gender
# is passed to Claude as the likely "you" addressee). When false, the broader
# "you"-form guidance still applies but no specific addressee is asserted.
ADDRESSEE_GENDER_HINT_ENABLED=true
# Optional: also write the produced SRT next to the source video on a mounted
# share, so the file name reflects the actual output language (.he.srt) regardless
# of how the calling client (e.g. Bazarr) names its own save. Set BOTH prefixes
# to enable; map the path the client sends (its view of the mount, e.g. "/media")
# to the server's view of the same mount (e.g. "Z:\media"). The SAVE_SRT_SUFFIX
# replaces the video's extension on the written file.
SAVE_SRT_VIDEO_PREFIX=
SAVE_SRT_LOCAL_PREFIX=
SAVE_SRT_SUFFIX=.he.srt
# Translation backend. "claude" (default) uses the Anthropic API; "local" uses
# a HuggingFace seq2seq model on the same GPU as Whisper. The LOCAL_* keys
# below are ignored unless TRANSLATION_BACKEND=local.
TRANSLATION_BACKEND=claude
# HuggingFace model ID. Default fits in ~1.2 GB VRAM at float16. Alternative:
# Helsinki-NLP/opus-mt-en-he (~300 MB, much faster, en->he only, lower quality).
LOCAL_TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
LOCAL_TRANSLATION_DEVICE=cuda
LOCAL_TRANSLATION_DTYPE=float16
LOCAL_BATCH_SIZE=16
LOCAL_MAX_LENGTH=512
# Best-effort gender hint prepended to the source text (local seq2seq models
# are not instruction-followers; leave off unless you've measured a benefit).
LOCAL_USE_GENDER_PREFIX=false
# Gender classification (Plan: improve-gender-detection).
# "pitch" (default) keeps the existing librosa.pyin + threshold path.
# "ml" uses the wav2vec2 audio-classification model alone.
# "ensemble" runs both; logs disagreements; ML decides (pitch is the fallback).
GENDER_CLASSIFIER=pitch
# HuggingFace model id for the ML classifier.
# Loaded on first request (singleton). ~1.2 GB on disk.
GENDER_ML_MODEL=alefiury/wav2vec2-large-xlsr-53-gender-recognition-librispeech
# When true, emit a SECOND *.he.srt side-file using the alternate classifier
# so the operator can A/B them on a real episode. Defaults to off.
GENDER_AB_OUTPUT=false
# Number of preceding source-language segments injected into each translate
# batch as "earlier in this scene" context. 0 disables.
TRANSLATE_CONTEXT_LINES=4
